{
  "name": "@jojovembh/cognito-cli-helper",
  "publishConfig": {
    "access": "public"
  },
  "version": "1.2.3",
  "description": "A CLI to easily test AWS Cognito user functionalities.",
  "license": "MIT",
  "author": "Gustavo Andrade Ferreira",
  "homepage": "https://github.com/jojovem/cognito-cli-helper#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jojovem/cognito-cli-helper.git"
  },
  "bugs": {
    "url": "https://github.com/jojovem/cognito-cli-helper/issues"
  },
  "type": "module",
  "main": "dist/cli.min.js",
  "bin": {
    "cognito-cli": "dist/cli.min.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "node esbuild.config.mjs",
    "start": "node dist/cli.min.js",
    "clean": "rm -rf dist .tsbuildinfo node_modules",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "npm test -- --watch --onlyChanged",
    "prepublishOnly": "npm run clean && npm ci && npm run test && npm run build",
    "release": "semantic-release --no-ci"
  },
  "types": "dist/cli.d.ts",
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1075.0",
    "@aws-sdk/credential-providers": "^3.1075.0",
    "cognito-srp-helper": "^2.3.5",
    "commander": "^15.0.0",
    "env-paths": "^4.0.0",
    "inquirer": "^14.0.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@swc/core": "^1.15.43",
    "@swc/helpers": "^0.5.23",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "aws-sdk-client-mock": "^4.1.0",
    "commitizen": "^4.3.2",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "mock-fs": "^5.5.0",
    "prettier": "^3.8.5",
    "semantic-release": "^25.0.5",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "aws",
    "cli",
    "cognito"
  ],
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
